<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="SyncTranslate Virtual Audio Driver"
    Manufacturer="SyncTranslate"
    Version="$(ProductVersion)"
    UpgradeCode="{55E95DAB-C7F8-41D9-B605-5E6F764985C0}"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of SyncTranslate Virtual Audio Driver is already installed." />
    <Property Id="REBOOT" Value="ReallySuppress"/>
    <MediaTemplate EmbedCab="yes" />

    <SummaryInformation Description="SyncTranslate Virtual Audio Driver MSI" Manufacturer="SyncTranslate" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="SyncTranslate Virtual Audio Driver" />
    </StandardDirectory>

    <Feature Id="Main" Title="SyncTranslate Virtual Audio Driver" Level="1">
      <ComponentGroupRef Id="DriverPayload" />
    </Feature>

    <ComponentGroup Id="DriverPayload" Directory="INSTALLFOLDER">
      <Files Include="$(PayloadDir)\**" />
    </ComponentGroup>

    <CustomAction
      Id="CleanStaleDriverPayload"
      Directory="INSTALLFOLDER"
      ExeCommand="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -Command &quot;$p='[INSTALLFOLDER]package'; if(Test-Path $p){ Remove-Item -LiteralPath $p -Recurse -Force -ErrorAction SilentlyContinue }&quot;"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <CustomAction
      Id="PrepareInstall"
      Directory="INSTALLFOLDER"
      ExeCommand="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -Command &quot;$d='[INSTALLFOLDER]'; $cert=Join-Path $d 'SyncTranslateVirtualAudioTest.cer'; if(Test-Path $cert){ Write-Host 'Importing certificate...'; Import-Certificate -FilePath $cert -CertStoreLocation Cert:\LocalMachine\Root -ErrorAction SilentlyContinue | Out-Null; Import-Certificate -FilePath $cert -CertStoreLocation Cert:\LocalMachine\TrustedPublisher -ErrorAction SilentlyContinue | Out-Null; Write-Host 'Certificate imported successfully' }&quot;"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <CustomAction
      Id="InstallDriverPackage"
      Directory="INSTALLFOLDER"
      ExeCommand="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]install_driver_package.ps1&quot; -PackageDir &quot;[INSTALLFOLDER]package&quot; -MsiPath &quot;[INSTALLFOLDER]SyncTranslateVirtualAudioDriver.msi&quot; -CertificatePath &quot;[INSTALLFOLDER]SyncTranslateVirtualAudioTest.cer&quot; -AllowHostInstall -SkipPreflight"
      Execute="deferred"
      Return="check"
      Impersonate="no" />

    <CustomAction
      Id="UninstallDriverPackage"
      Directory="INSTALLFOLDER"
      ExeCommand="&quot;[System64Folder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[INSTALLFOLDER]uninstall_driver_package.ps1&quot;"
      Execute="deferred"
      Return="ignore"
      Impersonate="no" />

    <InstallExecuteSequence>
      <Custom Action="CleanStaleDriverPayload" Before="InstallFiles" Condition="NOT REMOVE" />
      <Custom Action="PrepareInstall" After="InstallFiles" Condition="NOT REMOVE" />
      <Custom Action="InstallDriverPackage" After="PrepareInstall" Condition="NOT REMOVE" />
      <Custom Action="UninstallDriverPackage" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>
  </Package>
</Wix>
